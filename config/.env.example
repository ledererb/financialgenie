# FinancialGenie – Környezeti változók
# Másold config/.env néven és töltsd ki

# Anthropic API (AI mezőfelismerés)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Salesforce sandbox (ha van)
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=test  # 'test' = sandbox

# Általános
LOG_LEVEL=INFO
OUTPUT_DIR=output/
